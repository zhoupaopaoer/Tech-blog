---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SidebarLeft from "../../components/SidebarLeft.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";
import { getPublishedPosts, paginatePosts } from "../../utils/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const totalPages = Math.max(1, Math.ceil(posts.length / 12));

  return Array.from({ length: totalPages - 1 }, (_, index) => ({
    params: { page: String(index + 2) }
  }));
}

const posts = await getPublishedPosts();
const pageParam = Number(Astro.params.page || "1");
const pagination = paginatePosts(posts, pageParam, 12);
---

<BaseLayout>
  <section class="container home-feed-shell paged-feed-shell">
    <aside class="home-sidebar">
      <SidebarLeft currentPath={Astro.url.pathname} homeMode={true} />
    </aside>
    <div class="home-feed-main">
      <div class="feed-list">
        {pagination.items.map((post, index) => <PostCard post={post} index={index} />)}
      </div>
      <Pagination page={pagination.page} totalPages={pagination.totalPages} basePath="/" />
    </div>
  </section>
</BaseLayout>
