---
import PortalLayout from "../layouts/PortalLayout.astro";
import { siteConfig } from "../config/site";
import { getArchiveGroups, getPublishedPosts } from "../utils/blog";
import { withBase } from "../utils/links";

const posts = await getPublishedPosts();
const archives = getArchiveGroups(posts);
---

<PortalLayout title={`归档 | ${siteConfig.title}`} description="按年份查看文章归档">
  <section class="content-section">
    <div class="page-title">
      <p class="eyebrow">Archive</p>
      <h1>历史归档</h1>
      <p>按年份整理所有已发布文章。</p>
    </div>

    <div class="archive-stack">
      {
        archives.map((archive) => (
          <section class="archive-group" id={`year-${archive.year}`}>
            <div class="archive-year">{archive.year}</div>
            <div class="archive-list">
              {archive.posts.map((post) => (
                <a class="archive-item" href={withBase(`/blog/${post.id.replace(/\.md$/, "")}/`)}>
                  <strong>{post.data.title}</strong>
                  <span>{post.data.pubDate.toLocaleDateString("zh-CN")}</span>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</PortalLayout>
