---
import PortalLayout from "../../../layouts/PortalLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import Pagination from "../../../components/Pagination.astro";
import { siteConfig } from "../../../config/site";
import { getPublishedPosts, paginatePosts } from "../../../utils/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const totalPages = Math.max(1, Math.ceil(posts.length / 12));

  return Array.from({ length: totalPages - 1 }, (_, index) => ({
    params: { page: String(index + 2) }
  }));
}

const posts = await getPublishedPosts();
const pageParam = Number(Astro.params.page || "1");
const pagination = paginatePosts(posts, pageParam, 12);
---

<PortalLayout title={`文章第 ${pagination.page} 页 | ${siteConfig.title}`} description="博客文章分页列表">
  <section class="content-section">
    <div class="page-title">
      <p class="eyebrow">All Posts</p>
      <h1>文章列表</h1>
      <p>第 {pagination.page} 页，共 {pagination.totalPages} 页。</p>
    </div>
    <div class="feed-list">
      {pagination.items.map((post, index) => <PostCard post={post} index={index} />)}
    </div>
    <Pagination page={pagination.page} totalPages={pagination.totalPages} basePath="/blog/" />
  </section>
</PortalLayout>
