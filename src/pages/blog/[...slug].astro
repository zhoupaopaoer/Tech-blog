---
import { getCollection, render } from "astro:content";
import PortalLayout from "../../layouts/PortalLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { siteConfig } from "../../config/site";
import { getPublishedPosts, getRelatedPosts } from "../../utils/blog";
import { withBase } from "../../utils/links";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = await getPublishedPosts();
const relatedPosts = getRelatedPosts(post, posts);
---

<PortalLayout title={`${post.data.title} | ${siteConfig.title}`} description={post.data.description}>
  <article class="article article-page">
    <div class="article-head portal-prose-card">
      <p class="eyebrow">Post</p>
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>
          发布于 {post.data.pubDate.toLocaleDateString("zh-CN")}
        </time>
        {
          post.data.updatedDate && (
            <span>更新于 {post.data.updatedDate.toLocaleDateString("zh-CN")}</span>
          )
        }
        <span>{post.data.category}</span>
      </div>
      {
        post.data.tags.length > 0 && (
          <div class="tag-list">
            {post.data.tags.map((tag) => <a class="tag" href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>)}
          </div>
        )
      }
    </div>
    <div class="prose portal-prose-card">
      <Content />
    </div>
    {
      relatedPosts.length > 0 && (
        <section class="content-section related-section">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Related Posts</p>
              <h2>相关文章</h2>
            </div>
          </div>
          <div class="feed-list">
            {relatedPosts.map((relatedPost) => <PostCard post={relatedPost} />)}
          </div>
        </section>
      )
    }
  </article>
</PortalLayout>
