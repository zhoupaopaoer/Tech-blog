---
import PortalLayout from "../../layouts/PortalLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { siteConfig } from "../../config/site";
import { getAllCategories, getPublishedPosts } from "../../utils/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return getAllCategories(posts).map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts.filter((post) => post.data.category === category)
    }
  }));
}

const { category, posts } = Astro.props;
---

<PortalLayout title={`分类：${category} | ${siteConfig.title}`} description={`分类 ${category} 的文章列表`}>
  <section class="content-section">
    <div class="page-title">
      <p class="eyebrow">Category</p>
      <h1>{category}</h1>
      <p>共 {posts.length} 篇文章。</p>
    </div>
    <div class="feed-list">
      {posts.map((post, index) => <PostCard post={post} index={index} />)}
    </div>
  </section>
</PortalLayout>
