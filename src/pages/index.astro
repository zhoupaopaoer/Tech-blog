---
import BaseLayout from "../layouts/BaseLayout.astro";
import SidebarLeft from "../components/SidebarLeft.astro";
import PostCard from "../components/PostCard.astro";
import { siteConfig } from "../config/site";
import { getPublishedPosts } from "../utils/blog";
import { withBase } from "../utils/links";

const posts = await getPublishedPosts();
const recentPosts = posts.slice(0, 6);
---

<BaseLayout>
  <section
    class="hero-banner hero-banner-full"
    style={`background-image: linear-gradient(rgba(14, 21, 40, 0.28), rgba(14, 21, 40, 0.38)), url(${withBase(siteConfig.homeHero.image)})`}
  >
    <div class="hero-banner-inner">
      <p class="hero-banner-tip">欢迎来到我的博客</p>
      <h1>{siteConfig.homeHero.title}</h1>
      <p>{siteConfig.homeHero.subtitle}</p>
      <div class="hero-banner-actions">
        {
          siteConfig.homeHero.categories.map((category) => (
            <a class="hero-pill" href={withBase(`/categories/${encodeURIComponent(category)}/`)}>
              {category}
            </a>
          ))
        }
      </div>
      <a class="hero-scroll" href="#home-feed" aria-label="开始阅读并滚动到下一屏">
        <span>开始阅读</span>
        <span aria-hidden="true">↓</span>
      </a>
    </div>
  </section>

  <section class="container home-feed-shell" id="home-feed">
    <aside class="home-sidebar">
      <SidebarLeft currentPath={Astro.url.pathname} />
    </aside>
    <div class="home-feed-main">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Latest Articles</p>
          <h2>最近更新</h2>
        </div>
        <a href={withBase("/blog/")}>查看全部</a>
      </div>
      <div class="feed-list">
        {recentPosts.map((post, index) => <PostCard post={post} index={index} />)}
      </div>
    </div>
  </section>
</BaseLayout>
