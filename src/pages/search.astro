---
import PortalLayout from "../layouts/PortalLayout.astro";
import { siteConfig } from "../config/site";
import { getPublishedPosts } from "../utils/blog";
import { withBase } from "../utils/links";

const posts = await getPublishedPosts();
const searchIndex = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  tags: post.data.tags,
  url: withBase(`/blog/${post.id.replace(/\.md$/, "")}/`)
}));
---

<PortalLayout title={`搜索 | ${siteConfig.title}`} description="搜索博客内容">
  <section class="content-section search-page">
    <div class="page-title">
      <p class="eyebrow">Search</p>
      <h1>站内搜索</h1>
      <p>按标题、摘要、分类或标签快速筛选内容。</p>
    </div>

    <div class="search-panel portal-prose-card">
      <input
        id="search-input"
        class="search-input"
        type="search"
        placeholder="输入关键词，比如 Astro、部署、写作系统"
      />
      <div id="search-results" class="search-results"></div>
    </div>
  </section>

  <script is:inline define:vars={{ searchIndex }}>
    const input = document.querySelector("#search-input");
    const results = document.querySelector("#search-results");
    const entries = searchIndex;

    function render(items) {
      if (!results) return;
      if (items.length === 0) {
        results.innerHTML = '<p class="search-empty">没有匹配到内容。</p>';
        return;
      }

      results.innerHTML = items
        .map(
          (item) => `
            <a class="search-item" href="${item.url}">
              <strong>${item.title}</strong>
              <span>${item.category}</span>
              <p>${item.description}</p>
            </a>
          `
        )
        .join("");
    }

    render(entries);

    input?.addEventListener("input", (event) => {
      const keyword = event.target.value.trim().toLowerCase();

      if (!keyword) {
        render(entries);
        return;
      }

      const filtered = entries.filter((item) =>
        [item.title, item.description, item.category, ...(item.tags || [])]
          .join(" ")
          .toLowerCase()
          .includes(keyword)
      );

      render(filtered);
    });
  </script>
</PortalLayout>
