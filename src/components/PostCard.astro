---
import type { BlogPost } from "../utils/blog";
import { withBase } from "../utils/links";

interface Props {
  post: BlogPost;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const slug = post.id.replace(/\.md$/, "");
const coverImage = post.data.hero || "/images/cover-astro.svg";
---

<article class:list={["post-card", { reverse: index % 2 === 1 }]}>
  <a class="post-card-content" href={withBase(`/blog/${slug}/`)}>
    <div class="post-copy">
      <h2>{post.data.title}</h2>
      <div class="post-taxonomy">
        <span>{post.data.category}</span>
        <span>0 评论</span>
      </div>
      <p>{post.data.description}</p>
      <div class="post-footer-row">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("zh-CN")}
        </time>
        <div class="post-tag-row">
          {post.data.tags.slice(0, 4).map((tag) => <span class="tag-badge">{tag}</span>)}
        </div>
      </div>
    </div>
    <div class="post-cover-wrap">
      <img class="post-cover" src={withBase(coverImage)} alt={post.data.title} />
      <div class="post-cover-overlay">
        <h3 class="post-cover-title">{post.data.title}</h3>
        <p class="post-cover-subtitle">{post.data.description}</p>
        <span class="post-cover-author">{post.data.category}</span>
      </div>
    </div>
  </a>
</article>
