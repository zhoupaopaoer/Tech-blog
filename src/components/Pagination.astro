---
import { withBase } from "../utils/links";

interface Props {
  page: number;
  totalPages: number;
  basePath?: string;
}

const { page, totalPages, basePath = "/" } = Astro.props;

function getHref(targetPage: number) {
  if (basePath === "/") {
    return targetPage === 1 ? withBase("/") : withBase(`/page/${targetPage}/`);
  }

  return targetPage === 1
    ? withBase(basePath)
    : withBase(`${basePath.replace(/\/$/, "")}/page/${targetPage}/`);
}
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="文章分页">
      {page > 1 ? <a class="pagination-link" href={getHref(page - 1)}>上一页</a> : <span class="pagination-link disabled">上一页</span>}
      <div class="pagination-pages">
        {Array.from({ length: totalPages }, (_, index) => {
          const targetPage = index + 1;
          return (
            <a
              class:list={["pagination-page", { active: targetPage === page }]}
              href={getHref(targetPage)}
            >
              {targetPage}
            </a>
          );
        })}
      </div>
      {page < totalPages ? <a class="pagination-link" href={getHref(page + 1)}>下一页</a> : <span class="pagination-link disabled">下一页</span>}
    </nav>
  )
}
