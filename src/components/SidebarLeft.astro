---
import { siteConfig } from "../config/site";
import {
  getAllCategories,
  getAllTags,
  getPublishedPosts
} from "../utils/blog";
import { withBase } from "../utils/links";

interface Props {
  currentPath: string;
  homeMode?: boolean;
}

const { currentPath, homeMode = false } = Astro.props;
const posts = await getPublishedPosts();
const categories = getAllCategories(posts);
const tags = getAllTags(posts);
const latestPosts = posts.slice(0, 5);

function isActive(path: string) {
  const href = withBase(path);
  return path === "/"
    ? currentPath === withBase("/")
    : currentPath.startsWith(href);
}
---

<div class="sidebar-stack">
  <section class="sidebar-card profile-card">
    <img
      class="profile-avatar-image"
      src={withBase(siteConfig.profile.avatar)}
      alt={`${siteConfig.profile.name} avatar`}
    />
    <div class="profile-copy">
      <p class="sidebar-kicker">About Me</p>
      <h2>{siteConfig.profile.name}</h2>
      <p class="profile-tagline">{siteConfig.profile.tagline}</p>
      <p class="profile-bio">{siteConfig.profile.bio}</p>
    </div>
    <div class="profile-stats">
      <div class="stat-item">
        <span>文章</span>
        <strong>{posts.length}</strong>
      </div>
      <div class="stat-item">
        <span>分类</span>
        <strong>{categories.length}</strong>
      </div>
      <div class="stat-item">
        <span>标签</span>
        <strong>{tags.length}</strong>
      </div>
    </div>
    <div class="profile-socials">
      {
        siteConfig.socialLinks.map((link) => (
          <a
            class="profile-social"
            href={link.label === "RSS" ? withBase("/rss.xml") : link.href}
            target={link.label === "Email" || link.label === "RSS" ? undefined : "_blank"}
            rel={link.label === "Email" || link.label === "RSS" ? undefined : "noreferrer"}
            aria-label={link.label}
          >
            {link.label.slice(0, 2)}
          </a>
        ))
      }
    </div>
    <div class="profile-meta">
      <span>{siteConfig.profile.location}</span>
      <a href={`mailto:${siteConfig.profile.email}`}>{siteConfig.profile.email}</a>
    </div>
  </section>

  <section class="sidebar-card latest-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Latest</p>
      <h3>最近发布</h3>
    </div>
    <div class="latest-sidebar-list">
      {
        latestPosts.map((post) => (
          <a class="latest-sidebar-item" href={withBase(`/blog/${post.id.replace(/\.md$/, "")}/`)}>
            <img
              class="latest-sidebar-cover"
              src={withBase(post.data.hero || "/images/cover-astro.svg")}
              alt={post.data.title}
            />
            <div class="latest-sidebar-copy">
              <strong>{post.data.title}</strong>
              <span>{post.data.pubDate.toLocaleDateString("zh-CN")}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="sidebar-card announcement-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Notice</p>
      <h3>公告</h3>
    </div>
    <div class="announcement-body">
      <p class="announcement-title">欢迎来到 {siteConfig.title}</p>
      <div class="announcement-pill">免责声明</div>
      <p>⚠️ 本站内容仅代表个人观点，可转载，但请注明出处。</p>
      <p>⚠️ 本人分享内容仅供学习参考使用，请勿用于其他用途。</p>
      <div class="announcement-pill">关于我</div>
      <p>一枚混迹多年的程序员，喜欢做知识分享与项目记录。</p>
      <p>
        有问题欢迎
        <a href={`mailto:${siteConfig.profile.email}`}>联系我</a>
      </p>
    </div>
  </section>

  {
    !homeMode && (
  <section class="sidebar-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Navigation</p>
      <h3>站点导航</h3>
    </div>
    <nav class="sidebar-nav">
      {
        siteConfig.nav.map((item) => (
          <a class:list={["sidebar-link", { active: isActive(item.href) }]} href={withBase(item.href)}>
            <span>{item.label}</span>
          </a>
        ))
      }
    </nav>
  </section>
    )
  }

  {
    !homeMode && (
  <section class="sidebar-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Categories</p>
      <h3>文章分类</h3>
    </div>
    <div class="sidebar-list">
      {
        categories.map((category) => (
          <a class="sidebar-row" href={withBase(`/categories/${encodeURIComponent(category)}/`)}>
            <span>{category}</span>
            <span>{posts.filter((post) => post.data.category === category).length}</span>
          </a>
        ))
      }
    </div>
  </section>
    )
  }
</div>
