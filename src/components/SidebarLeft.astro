---
import { siteConfig } from "../config/site";
import {
  getAllCategories,
  getAllTags,
  getPublishedPosts
} from "../utils/blog";
import { withBase } from "../utils/links";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const posts = await getPublishedPosts();
const categories = getAllCategories(posts);
const tags = getAllTags(posts);

function isActive(path: string) {
  const href = withBase(path);
  return path === "/"
    ? currentPath === withBase("/")
    : currentPath.startsWith(href);
}
---

<div class="sidebar-stack">
  <section class="sidebar-card profile-card">
    <img
      class="profile-avatar-image"
      src={withBase(siteConfig.profile.avatar)}
      alt={`${siteConfig.profile.name} avatar`}
    />
    <div class="profile-copy">
      <p class="sidebar-kicker">About Me</p>
      <h2>{siteConfig.profile.name}</h2>
      <p class="profile-tagline">{siteConfig.profile.tagline}</p>
      <p class="profile-bio">{siteConfig.profile.bio}</p>
    </div>
    <div class="profile-stats">
      <div class="stat-item">
        <span>文章</span>
        <strong>{posts.length}</strong>
      </div>
      <div class="stat-item">
        <span>分类</span>
        <strong>{categories.length}</strong>
      </div>
      <div class="stat-item">
        <span>标签</span>
        <strong>{tags.length}</strong>
      </div>
    </div>
    <div class="profile-socials">
      {
        siteConfig.socialLinks.map((link) => (
          <a
            class="profile-social"
            href={link.label === "RSS" ? withBase("/rss.xml") : link.href}
            target={link.label === "Email" || link.label === "RSS" ? undefined : "_blank"}
            rel={link.label === "Email" || link.label === "RSS" ? undefined : "noreferrer"}
            aria-label={link.label}
          >
            {link.label.slice(0, 2)}
          </a>
        ))
      }
    </div>
    <div class="profile-meta">
      <span>{siteConfig.profile.location}</span>
      <a href={`mailto:${siteConfig.profile.email}`}>{siteConfig.profile.email}</a>
    </div>
  </section>

  <section class="sidebar-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Navigation</p>
      <h3>站点导航</h3>
    </div>
    <nav class="sidebar-nav">
      {
        siteConfig.nav.map((item) => (
          <a class:list={["sidebar-link", { active: isActive(item.href) }]} href={withBase(item.href)}>
            <span>{item.label}</span>
          </a>
        ))
      }
    </nav>
  </section>

  <section class="sidebar-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Categories</p>
      <h3>文章分类</h3>
    </div>
    <div class="sidebar-list">
      {
        categories.map((category) => (
          <a class="sidebar-row" href={withBase(`/categories/${encodeURIComponent(category)}/`)}>
            <span>{category}</span>
            <span>{posts.filter((post) => post.data.category === category).length}</span>
          </a>
        ))
      }
    </div>
  </section>
</div>
