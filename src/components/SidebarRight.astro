---
import { siteConfig } from "../config/site";
import { getAllTags, getPublishedPosts } from "../utils/blog";
import { withBase } from "../utils/links";

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 5);
const tags = getAllTags(posts).slice(0, 10);
---

<div class="sidebar-stack">
  <section class="sidebar-card notice-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Announcement</p>
      <h3>{siteConfig.announcement.title}</h3>
    </div>
    <p>{siteConfig.announcement.content}</p>
  </section>

  <section class="sidebar-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Latest</p>
      <h3>最新发布</h3>
    </div>
    <div class="latest-list">
      {
        latestPosts.map((post) => (
          <a class="latest-item" href={withBase(`/blog/${post.id.replace(/\.md$/, "")}/`)}>
            <strong>{post.data.title}</strong>
            <span>{post.data.pubDate.toLocaleDateString("zh-CN")}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="sidebar-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Topics</p>
      <h3>热门标签</h3>
    </div>
    <div class="mini-tag-list">
      {
        tags.map((tag) => (
          <a class="mini-tag" href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>
            #{tag}
          </a>
        ))
      }
    </div>
  </section>

  <section class="sidebar-card action-card">
    <div class="sidebar-heading">
      <p class="sidebar-kicker">Guestbook</p>
      <h3>留言板</h3>
    </div>
    <p>如果你看完文章有反馈、建议或想法，可以通过留言页或 GitHub 联系我。</p>
    <a class="sidebar-button" href={withBase("/guestbook/")}>前往留言</a>
  </section>
</div>
