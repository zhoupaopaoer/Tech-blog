---
import { siteConfig } from "../config/site";
import { withBase } from "../utils/links";
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-copy">
      <p class="footer-kicker">Publishing from the edge of notes and code.</p>
      <p>© {new Date().getFullYear()} {siteConfig.author}. Built with Astro.</p>
    </div>
    <div class="social-links">
      {
        siteConfig.socialLinks.map((link) => (
          <a
            href={link.href.startsWith("/") ? withBase(link.href) : link.href}
            target={link.href.startsWith("mailto:") || link.href.startsWith("/") ? undefined : "_blank"}
            rel={link.href.startsWith("mailto:") || link.href.startsWith("/") ? undefined : "noreferrer"}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
